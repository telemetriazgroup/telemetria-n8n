# ── n8n telemetría — copiar a .env y ajustar ───────────────────────────────
# Servidor aplicaciones: 161.132.53.51:7001
# URL pública (proxy ztrack.app): https://ztrack.app/automatico/

# ── Identidad pública (subruta /automatico/ vía proxy strip-prefix) ─────────
# N8N_PATH NO monta rutas en el backend en n8n 2.x: el proxy Apache QUITA
# /automatico/ al reenviar. Ver infra/apache-ztrack-automatico.conf
N8N_HOST=ztrack.app
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/automatico/
N8N_EDITOR_BASE_URL=https://ztrack.app/automatico/
WEBHOOK_URL=https://ztrack.app/automatico/

# ── Proxy y cookies ────────────────────────────────────────────────────────
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true

# ── Zona horaria ───────────────────────────────────────────────────────────
GENERIC_TIMEZONE=America/Lima
TZ=America/Lima

# ── Opcional: Postgres INTERNO de n8n (workflows, credenciales n8n) ────────
# Por defecto n8n usa SQLite en el volumen Docker — NO necesitas descomentar esto en F0.
# Si descomentas DB_TYPE=postgresdb, PRIMERO ejecuta:
#   psql -U postgres -f postgres/02-n8n-internal-db.sql
# y usa la MISMA contraseña aquí y en el SQL.
#
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=161.132.53.51
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n_telemetria
# DB_POSTGRESDB_USER=n8n_telemetria
# DB_POSTGRESDB_PASSWORD=CAMBIAR_N8N_PASSWORD
#
# Si Postgres está en el mismo host que Docker, desde el contenedor el host suele ser:
# DB_POSTGRESDB_HOST=host.docker.internal   (Linux: extra_hosts en compose)
# o la IP del bridge docker0, ej. 172.17.0.1 — NO uses 161.132.53.51 si pg_hba
# no acepta conexiones desde la red Docker.

# ── Postgres negocio (credencial en n8n, no leída por el contenedor) ────────
# TELEMETRIA_DB_HOST=161.132.53.51
# TELEMETRIA_DB_PORT=5432
# TELEMETRIA_DB_NAME=telemetria
# TELEMETRIA_DB_USER=telemetria_app
# TELEMETRIA_DB_PASSWORD=CAMBIAR_PASSWORD

# ── OAuth Gmail — redirect URI en Google Cloud Console ─────────────────────
# https://ztrack.app/automatico/rest/oauth2-credential/callback
