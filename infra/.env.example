# ── n8n telemetría — copiar a .env ─────────────────────────────────────────
#
# MODELO SIMPLE:
#   • Contenedor n8n escucha en RAÍZ:  http://161.132.53.51:7001/
#   • ztrack.app mapea /automatico/ → :7001/  (Apache quita el prefijo)
#   • URL pública de uso: https://ztrack.app/automatico/
#
# Las tres variables de "URL pública" le dicen a n8n bajo qué ruta lo ve
# el navegador (OAuth, webhooks, enlaces JS). NO crean rutas /automatico/
# dentro del contenedor.

N8N_HOST=ztrack.app
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/automatico/
N8N_EDITOR_BASE_URL=https://ztrack.app/automatico/
WEBHOOK_URL=https://ztrack.app/automatico/

N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true

GENERIC_TIMEZONE=America/Lima
TZ=America/Lima

# ── NO descomentar DB_* en F0 (SQLite en volumen Docker) ───────────────────
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=172.17.0.1
# DB_POSTGRESDB_DATABASE=n8n_telemetria
# DB_POSTGRESDB_USER=n8n_telemetria
# DB_POSTGRESDB_PASSWORD=CAMBIAR_N8N_PASSWORD

# OAuth Gmail (Google Cloud Console):
# https://ztrack.app/automatico/rest/oauth2-credential/callback
