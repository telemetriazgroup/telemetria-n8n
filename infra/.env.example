# ── n8n telemetría + PostgreSQL Docker ──────────────────────────────────────
# cp .env.example .env  →  editar contraseñas  →  docker compose up -d

# ── PostgreSQL negocio (contenedor postgres-telemetria) ─────────────────────
TELEMETRIA_DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# ── n8n — URLs públicas (proxy ztrack.app/automatico/ → :7001/) ───────────
N8N_HOST=ztrack.app
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PATH=/automatico/
N8N_EDITOR_BASE_URL=https://ztrack.app/automatico/
WEBHOOK_URL=https://ztrack.app/automatico/

N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true

GENERIC_TIMEZONE=America/Lima
TZ=America/Lima

# ── Credencial Postgres en n8n (F0 paso 3 / F1) ───────────────────────────
# Host:     postgres-telemetria
# Puerto:   5432
# Base:     telemetria
# Usuario:  telemetria_app
# Password: mismo valor que TELEMETRIA_DB_PASSWORD

# Adminer (UI BD): http://161.132.53.51:7901
#   Sistema: PostgreSQL | Servidor: postgres-telemetria
#   Usuario: telemetria_app | Base: telemetria

# OAuth Gmail:
# https://ztrack.app/automatico/rest/oauth2-credential/callback

# NO activar DB_TYPE=postgresdb — n8n usa SQLite en su volumen (n8n_telemetria_data)

# ── Control correo (FastAPI + React :7201) ───────────────────────────────────
# UI: http://161.132.53.51:7201
# Migración tablas control_*:
#   docker exec -i postgres-telemetria psql -U telemetria_app -d telemetria \
#     < ../infra/postgres/06-control-correo.sql
N8N_API_KEY=
N8N_WORKFLOW_ID=
N8N_WEBHOOK_PATH=historico-run
CONTROL_POLL_INTERVAL_SEC=600
CONTROL_EXEC_TIMEOUT_MIN=15
CONTROL_SCHEDULER_ENABLED=true
PROGRAM_RANGE_START=2025-01-01
PROGRAM_RANGE_END=2026-06-30
CONTROL_CORS_ORIGINS=http://localhost:7201,http://161.132.53.51:7201
